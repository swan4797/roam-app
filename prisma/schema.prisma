generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Auth Models (NextAuth compatible)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // Hashed password for credentials auth
  name          String?
  image         String?
  emailVerified DateTime?
  baseCurrency  String    @default("GBP") // User's home currency for conversions
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts         Account[] // NextAuth accounts (OAuth providers - for future use)
  sessions         Session[]
  bankConnections  BankConnection[]
  invoices         Invoice[]
  createdGroups    ExpenseGroup[] // Groups this user created
  groupMemberships GroupMember[] // Group memberships

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// Bank Connection Models (TrueLayer)
// ============================================================================

model BankConnection {
  id                    String    @id @default(cuid())
  userId                String
  provider              String    @default("truelayer") // For future multi-provider support
  institutionId         String // TrueLayer institution ID
  institutionName       String // "Monzo", "Starling", etc.
  accessTokenEncrypted  String    @db.Text // AES-256 encrypted
  refreshTokenEncrypted String    @db.Text // AES-256 encrypted
  accessTokenExpiresAt  DateTime
  consentExpiresAt      DateTime? // TrueLayer consent expiry (typically 90 days)
  lastSyncedAt          DateTime?
  syncStatus            SyncStatus @default(PENDING)
  syncError             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts BankAccount[]

  @@map("bank_connections")
}

enum SyncStatus {
  PENDING
  SYNCING
  COMPLETED
  FAILED
}

model BankAccount {
  id               String   @id @default(cuid())
  bankConnectionId String
  externalId       String // TrueLayer account ID
  accountType      String // "TRANSACTION", "SAVINGS", etc.
  displayName      String // User-friendly name
  currency         String // ISO 4217 currency code
  accountNumber    String? // Last 4 digits only
  sortCode         String? // UK sort code
  iban             String? // For EU accounts
  balance          Decimal? @db.Decimal(19, 4)
  balanceUpdatedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  bankConnection BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@unique([bankConnectionId, externalId])
  @@map("bank_accounts")
}

// ============================================================================
// Transaction Models
// ============================================================================

model Transaction {
  id                    String    @id @default(cuid())
  bankAccountId         String
  externalId            String // TrueLayer transaction ID

  // Raw data from TrueLayer
  amount                Decimal   @db.Decimal(19, 4) // Original amount (can be negative for debits)
  currency              String // Original currency
  transactionDate       DateTime // When the transaction occurred
  settlementDate        DateTime? // When it settled
  description           String // Raw merchant description
  transactionType       String // "DEBIT", "CREDIT", etc.
  transactionCategory   String? // TrueLayer's category
  merchantName          String? // TrueLayer's merchant name if available

  // Enrichment data (populated by background jobs)
  normalisedMerchant    String? // AI-cleaned merchant name ("AMZN MKTP GB" -> "Amazon")
  categoryId            String?

  // FX enrichment (for foreign currency transactions)
  amountInBase          Decimal?  @db.Decimal(19, 4) // Amount in user's base currency
  midMarketRate         Decimal?  @db.Decimal(19, 8) // Mid-market rate on transaction date
  bankRate              Decimal?  @db.Decimal(19, 8) // Rate the bank actually charged
  estimatedFxFee        Decimal?  @db.Decimal(19, 4) // Difference in base currency
  estimatedFxFeePercent Decimal?  @db.Decimal(5, 4) // Percentage markup
  wiseRate              Decimal?  @db.Decimal(19, 8) // What Wise would have charged
  wiseSavings           Decimal?  @db.Decimal(19, 4) // Potential savings with Wise

  // Transfer detection
  isInternalTransfer    Boolean   @default(false)
  linkedTransactionId   String?   @unique // Points to counterpart transaction

  // Metadata
  enrichedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  bankAccount        BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category           Category?         @relation(fields: [categoryId], references: [id])
  linkedTransaction  Transaction?      @relation("LinkedTransactions", fields: [linkedTransactionId], references: [id])
  linkedFrom         Transaction?      @relation("LinkedTransactions")
  invoicePayments    InvoicePayment[]

  @@unique([bankAccountId, externalId])
  @@index([transactionDate])
  @@index([bankAccountId, transactionDate])
  @@map("transactions")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique // "Shopping", "Travel", "Food & Drink", etc.
  icon      String? // Emoji or icon identifier
  color     String? // Hex color for UI
  createdAt DateTime @default(now())

  transactions Transaction[]

  @@map("categories")
}

// ============================================================================
// Invoice Models
// ============================================================================

model Invoice {
  id           String        @id @default(cuid())
  userId       String
  clientName   String
  description  String?
  amount       Decimal       @db.Decimal(19, 4)
  currency     String // Invoice currency
  amountInBase Decimal       @db.Decimal(19, 4) // Converted to user's base currency
  issuedAt     DateTime
  dueAt        DateTime
  status       InvoiceStatus @default(UNPAID)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments InvoicePayment[]

  @@index([userId, status])
  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

model InvoicePayment {
  id            String      @id @default(cuid())
  invoiceId     String
  transactionId String
  amount        Decimal     @db.Decimal(19, 4) // Amount of this payment
  matchType     MatchType // How the match was determined
  confirmedAt   DateTime? // When the user confirmed (null for auto-confirmed)
  createdAt     DateTime    @default(now())

  // Relations
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, transactionId])
  @@map("invoice_payments")
}

enum MatchType {
  EXACT_AMOUNT // Auto-confirmed
  FUZZY_AMOUNT // Within 5%, user confirmed
  MANUAL       // User manually linked
}

// ============================================================================
// Exchange Rate Cache
// ============================================================================

model ExchangeRate {
  id           String   @id @default(cuid())
  baseCurrency String // e.g., "USD"
  date         DateTime @db.Date // Rate date
  rates        Json // { "GBP": 0.79, "EUR": 0.92, ... }
  source       String   @default("openexchangerates")
  fetchedAt    DateTime @default(now())

  @@unique([baseCurrency, date, source])
  @@index([date])
  @@map("exchange_rates")
}

// ============================================================================
// AI Insights
// ============================================================================

model MonthlyInsight {
  id        String   @id @default(cuid())
  userId    String
  month     DateTime @db.Date // First day of month
  summary   String   @db.Text // AI-generated plain English summary
  data      Json // Structured data for the summary (spending by category, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@map("monthly_insights")
}

// ============================================================================
// Group Expense Splitting (Splitwise-style with FX awareness)
// ============================================================================

model ExpenseGroup {
  id          String   @id @default(cuid())
  name        String // "Trip to Japan", "Flatmates", etc.
  description String?
  currency    String   @default("GBP") // Default currency for the group
  imageUrl    String?
  createdById String // User who created the group
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members     GroupMember[]
  expenses    GroupExpense[]

  @@index([createdById])
  @@map("expense_groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String? // Null if member is not a registered user
  name      String // Display name (from User or manually entered)
  email     String? // Email for non-registered members
  createdAt DateTime @default(now())

  // Relations
  group             ExpenseGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  paidExpenses      GroupExpense[]    @relation("PaidBy")
  splits            ExpenseSplit[]
  settlementsFrom   GroupSettlement[] @relation("SettlementFrom")
  settlementsTo     GroupSettlement[] @relation("SettlementTo")

  @@unique([groupId, email])
  @@unique([groupId, userId])
  @@index([groupId])
  @@map("group_members")
}

model GroupExpense {
  id          String    @id @default(cuid())
  groupId     String
  paidById    String // GroupMember who paid
  description String
  amount      Decimal   @db.Decimal(19, 4)
  currency    String // Currency of the expense
  category    String? // "Food", "Transport", "Accommodation", etc.
  expenseDate DateTime  @default(now())
  splitType   SplitType @default(EQUAL) // How to split the expense
  notes       String?
  receiptUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // FX fields (populated when expense currency differs from group currency)
  amountInGroupCurrency Decimal? @db.Decimal(19, 4)
  midMarketRate         Decimal? @db.Decimal(19, 8)
  actualRate            Decimal? @db.Decimal(19, 8)
  estimatedFxFee        Decimal? @db.Decimal(19, 4)

  // Relations
  group  ExpenseGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy GroupMember    @relation("PaidBy", fields: [paidById], references: [id])
  splits ExpenseSplit[]

  @@index([groupId])
  @@index([paidById])
  @@index([expenseDate])
  @@map("group_expenses")
}

enum SplitType {
  EQUAL        // Split equally among all members
  EXACT        // Specific amounts per person
  PERCENTAGE   // Percentage-based split
  SHARES       // Share-based (e.g., 2 shares vs 1 share)
}

model ExpenseSplit {
  id         String  @id @default(cuid())
  expenseId  String
  memberId   String
  amount     Decimal @db.Decimal(19, 4) // Amount this member owes
  percentage Decimal? @db.Decimal(5, 2) // Percentage if using percentage split
  shares     Int? // Number of shares if using shares split
  isPaid     Boolean @default(false) // Marked when settled

  // FX awareness for the split
  amountInMemberCurrency Decimal? @db.Decimal(19, 4) // If member uses different currency
  memberCurrency         String? // Member's preferred currency
  fxFeeOnSplit           Decimal? @db.Decimal(19, 4) // FX fee if settling in different currency

  // Relations
  expense GroupExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member  GroupMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([expenseId, memberId])
  @@index([memberId])
  @@map("expense_splits")
}

model GroupSettlement {
  id             String           @id @default(cuid())
  groupId        String
  fromMemberId   String // Who is paying
  toMemberId     String // Who is receiving
  amount         Decimal          @db.Decimal(19, 4)
  currency       String // Currency of the settlement
  settlementDate DateTime         @default(now())
  status         SettlementStatus @default(PENDING)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // FX fields (when settling in different currency than group default)
  amountInGroupCurrency Decimal? @db.Decimal(19, 4)
  midMarketRate         Decimal? @db.Decimal(19, 8)
  actualRate            Decimal? @db.Decimal(19, 8)
  estimatedFxFee        Decimal? @db.Decimal(19, 4)
  wiseSavings           Decimal? @db.Decimal(19, 4) // What they'd save using Wise

  // Relations
  fromMember GroupMember @relation("SettlementFrom", fields: [fromMemberId], references: [id])
  toMember   GroupMember @relation("SettlementTo", fields: [toMemberId], references: [id])

  @@index([groupId])
  @@index([fromMemberId])
  @@index([toMemberId])
  @@map("group_settlements")
}

enum SettlementStatus {
  PENDING   // Settlement requested
  CONFIRMED // Both parties confirmed
  COMPLETED // Payment made
}
